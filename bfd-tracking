<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BFD Delivery Tracking</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600;700;800;900&family=Barlow+Condensed:wght@700;800;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--bg:#f0f0f0;--white:#fff;--surface2:#f7f7f7;--border:#e8e8e8;--border2:#d4d4d4;--text:#111;--muted:#888;--muted2:#bbb;--bassett:#c0281c;--bassett-light:#fff3f2;--bassett-mid:#f5c0bc;--enjoy:#111;--enjoy-light:#f5f5f5;--delivered:#16a34a;--delivered-light:#f0fdf4;--delivered-mid:#86efac;--transit:#d97706;--transit-light:#fffbeb;--transit-mid:#fcd34d;--pending-mid:#e5e7eb;--shadow-sm:0 1px 4px rgba(0,0,0,.07);--shadow-md:0 4px 16px rgba(0,0,0,.10);--shadow-lg:0 8px 32px rgba(0,0,0,.13);--radius:12px;--radius-lg:18px}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Barlow',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;-webkit-font-smoothing:antialiased}
#login-screen{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:24px;background:#1a1a1a;background-image:radial-gradient(ellipse at 20% 50%,rgba(192,40,28,.15) 0%,transparent 60%),radial-gradient(ellipse at 80% 20%,rgba(37,99,235,.08) 0%,transparent 50%)}
.login-wrap{width:100%;max-width:440px;display:flex;flex-direction:column;gap:12px;animation:fadeUp .5s ease both}
@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
.login-wordmark{text-align:center;margin-bottom:8px}
.login-wordmark-text{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:52px;letter-spacing:4px;text-transform:uppercase;color:#fff}
.login-wordmark-sub{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#666;margin-top:4px}
.role-cards{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}
.role-card{background:#242424;border:2px solid #333;border-radius:var(--radius-lg);padding:20px 10px 16px;cursor:pointer;transition:all .2s;display:flex;flex-direction:column;align-items:center;gap:10px}
.role-card:hover{border-color:#555;transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.3)}
.role-card.driver.active{border-color:#2563eb;background:rgba(37,99,235,.12)}
.role-card.bassett.active{border-color:var(--bassett);background:rgba(192,40,28,.12)}
.role-card.enjoy.active{border-color:#fff;background:rgba(255,255,255,.08)}
.role-logo-wrap{width:64px;height:48px;display:flex;align-items:center;justify-content:center}
.role-logo-wrap img{max-width:100%;max-height:100%;object-fit:contain;border-radius:4px}
.role-driver-icon{width:64px;height:48px;display:flex;align-items:center;justify-content:center;font-size:32px}
.role-label{font-family:'Barlow Condensed',sans-serif;font-weight:700;font-size:14px;letter-spacing:1.5px;text-transform:uppercase;color:#aaa}
.role-card.active .role-label{color:#fff}
.pin-card{background:#242424;border:1.5px solid #333;border-radius:var(--radius-lg);padding:24px;display:flex;flex-direction:column;gap:14px}
.pin-label{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:#666;text-align:center}
.pin-dots{display:flex;justify-content:center;gap:14px}
.pin-dot{width:14px;height:14px;border-radius:50%;background:#333;transition:all .15s}
.pin-dot.filled{background:#fff;transform:scale(1.15)}
.numpad{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.numpad-btn{background:#1a1a1a;border:1.5px solid #333;border-radius:10px;padding:16px 8px;color:#fff;font-family:'Barlow',sans-serif;font-weight:700;font-size:20px;cursor:pointer;transition:all .12s;text-align:center}
.numpad-btn:hover{background:#2a2a2a;border-color:#555}
.numpad-btn:active{transform:scale(.95);background:#333}
.numpad-btn.del{font-size:16px;color:#888}
.sign-in-btn{width:100%;padding:18px;background:#fff;color:#111;border:none;border-radius:12px;font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:18px;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all .18s}
.sign-in-btn:hover{background:#e8e8e8;transform:translateY(-1px)}
.login-error{text-align:center;color:#f87171;font-size:13px;font-weight:600;min-height:18px;font-family:'DM Mono',monospace}
.sync-status{display:flex;align-items:center;justify-content:center;gap:6px;font-family:'DM Mono',monospace;font-size:11px;letter-spacing:1px;color:#555;min-height:18px}
.sync-dot{width:7px;height:7px;border-radius:50%;background:#555}
.sync-dot.green{background:#16a34a;box-shadow:0 0 6px #16a34a}
.sync-dot.red{background:#ef4444}
.sync-dot.pulse{animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.app-header{background:var(--white);border-bottom:2px solid var(--border);padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:64px;position:sticky;top:0;z-index:100;box-shadow:var(--shadow-sm)}
.header-left{display:flex;align-items:center;gap:16px}
.header-logo{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:24px;letter-spacing:3px;text-transform:uppercase;color:var(--text)}
.header-divider{width:1px;height:28px;background:var(--border2)}
.header-brand-logo{height:32px;width:auto;object-fit:contain}
.header-role{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted)}
.header-right{display:flex;align-items:center;gap:12px}
.header-sync{display:flex;align-items:center;gap:5px;font-family:'DM Mono',monospace;font-size:10px;color:var(--muted);letter-spacing:.5px}
.header-sync-dot{width:6px;height:6px;border-radius:50%;background:var(--muted)}
.header-sync-dot.live{background:#16a34a;box-shadow:0 0 5px #16a34a}
.header-sync-dot.pulse{animation:pulse 1.5s infinite}
.logout-btn{background:none;border:1.5px solid var(--border2);border-radius:8px;color:var(--muted);font-size:12px;font-weight:700;font-family:'Barlow',sans-serif;padding:8px 16px;cursor:pointer;text-transform:uppercase}
.logout-btn:hover{color:var(--text);border-color:var(--text)}
.app-main{max-width:900px;margin:0 auto;padding:32px 20px}
.controls-bar{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:24px;align-items:center}
.account-tabs{display:flex;background:var(--white);border:2px solid var(--border);border-radius:var(--radius);padding:4px;box-shadow:var(--shadow-sm)}
.tab-btn{padding:9px 20px;border-radius:8px;border:none;background:none;color:var(--muted);font-family:'Barlow',sans-serif;font-weight:700;font-size:14px;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:8px}
.tab-btn img{height:18px;width:auto;object-fit:contain;opacity:.4;transition:opacity .15s}
.tab-btn.active-bassett{background:var(--bassett-light);color:var(--bassett)}.tab-btn.active-bassett img{opacity:1}
.tab-btn.active-enjoy{background:var(--enjoy-light);color:var(--enjoy)}.tab-btn.active-enjoy img{opacity:.8}
.date-picker{background:var(--white);border:2px solid var(--border);border-radius:var(--radius);padding:10px 14px;color:var(--text);font-family:'DM Mono',monospace;font-size:13px;outline:none;box-shadow:var(--shadow-sm);cursor:pointer}
.icon-btn{background:var(--white);border:2px solid var(--border);border-radius:var(--radius);padding:10px 18px;color:var(--text);font-family:'Barlow',sans-serif;font-weight:700;font-size:14px;cursor:pointer;transition:all .15s;display:flex;align-items:center;gap:7px;box-shadow:var(--shadow-sm)}
.icon-btn:hover{border-color:var(--border2);box-shadow:var(--shadow-md);transform:translateY(-1px)}
.search-wrap{position:relative;flex:1;min-width:200px}
.search-icon{position:absolute;left:13px;top:50%;transform:translateY(-50%);color:var(--muted2);pointer-events:none;font-size:14px}
.search-input{width:100%;background:var(--white);border:2px solid var(--border);border-radius:var(--radius);padding:10px 14px 10px 38px;color:var(--text);font-family:'Barlow',sans-serif;font-size:14px;outline:none;box-shadow:var(--shadow-sm)}
.search-input::placeholder{color:var(--muted2);font-weight:400}
.stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:28px}
.stat-card{background:var(--white);border-radius:var(--radius-lg);padding:20px 16px;box-shadow:var(--shadow-sm);border:2px solid transparent}
.stat-card.delivered{border-color:var(--delivered-mid)}.stat-card.transit{border-color:var(--transit-mid)}.stat-card.pending{border-color:var(--pending-mid)}
.stat-num{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:48px;line-height:1}
.stat-card.delivered .stat-num{color:var(--delivered)}.stat-card.transit .stat-num{color:var(--transit)}.stat-card.pending .stat-num{color:#aaa}
.stat-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-top:4px}
.section-label{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:12px;padding-left:2px}
.delivery-list{display:flex;flex-direction:column;gap:10px}
.delivery-card{background:var(--white);border:2px solid var(--border);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-sm);transition:box-shadow .2s,transform .2s}
.delivery-card:hover{box-shadow:var(--shadow-md);transform:translateY(-1px)}
.delivery-card.status-delivered{border-left:5px solid var(--delivered)}.delivery-card.status-transit{border-left:5px solid var(--transit)}.delivery-card.status-pending{border-left:5px solid var(--pending-mid)}
.card-main{padding:18px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px;cursor:pointer;user-select:none}
.card-info{flex:1;min-width:0}
.card-name{font-weight:800;font-size:17px;color:var(--text);margin-bottom:3px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.card-address{color:var(--muted);font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.card-meta{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted2);margin-top:4px}
.card-right{display:flex;flex-direction:column;align-items:flex-end;gap:6px;flex-shrink:0}
.card-badge{font-family:'Barlow',sans-serif;font-weight:700;font-size:12px;padding:5px 12px;border-radius:20px;white-space:nowrap}
.badge-delivered{background:var(--delivered-light);color:var(--delivered);border:1.5px solid var(--delivered-mid)}
.badge-transit{background:var(--transit-light);color:var(--transit);border:1.5px solid var(--transit-mid)}
.badge-pending{background:#f9fafb;color:#9ca3af;border:1.5px solid var(--pending-mid)}
.chevron{color:var(--muted2);font-size:12px;transition:transform .2s}
.chevron.open{transform:rotate(180deg)}
.card-expanded{display:none;border-top:2px solid var(--border);padding:20px;background:var(--surface2);flex-direction:column;gap:14px}
.card-expanded.open{display:flex}
.action-row{display:flex;gap:10px;flex-wrap:wrap}
.action-btn{padding:11px 20px;border-radius:10px;border:2px solid;font-family:'Barlow',sans-serif;font-weight:700;font-size:14px;cursor:pointer;transition:all .15s;background:var(--white)}
.action-btn.deliver{border-color:var(--delivered-mid);color:var(--delivered)}.action-btn.deliver:hover,.action-btn.deliver.active{background:var(--delivered);color:#fff;border-color:var(--delivered)}
.action-btn.transit{border-color:var(--transit-mid);color:var(--transit)}.action-btn.transit:hover,.action-btn.transit.active{background:var(--transit);color:#fff;border-color:var(--transit)}
.action-btn.reset{border-color:var(--border2);color:var(--muted)}.action-btn.reset:hover{color:var(--text);border-color:var(--muted)}
.note-input{background:var(--white);border:2px solid var(--border);border-radius:10px;padding:12px 16px;color:var(--text);font-family:'Barlow',sans-serif;font-size:15px;resize:none;outline:none;width:100%;min-height:80px}
.note-input::placeholder{color:var(--muted2)}
.photo-row{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.photo-upload-label{display:flex;align-items:center;gap:7px;padding:10px 16px;border:2px dashed var(--border2);border-radius:10px;color:var(--muted);font-size:14px;font-weight:700;cursor:pointer;font-family:'Barlow',sans-serif;background:var(--white)}
.photo-upload-label:hover{border-color:var(--muted);color:var(--text)}
.photo-thumb{width:60px;height:60px;border-radius:8px;object-fit:cover;border:2px solid var(--border)}
.timestamp-line{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted)}
.client-hero{border-radius:var(--radius-lg);padding:32px;margin-bottom:28px;display:flex;align-items:center;justify-content:space-between;gap:20px}
.client-hero.bassett{background:linear-gradient(135deg,#c0281c 0%,#8b1e14 100%);box-shadow:0 8px 32px rgba(192,40,28,.25)}
.client-hero.enjoy{background:linear-gradient(135deg,#1a1a1a 0%,#333 100%);box-shadow:0 8px 32px rgba(0,0,0,.2)}
.client-hero-eyebrow{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:3px;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:6px}
.client-hero-title{font-family:'Barlow Condensed',sans-serif;font-weight:900;font-size:36px;letter-spacing:1px;text-transform:uppercase;color:#fff;line-height:1;margin-bottom:6px}
.client-hero-sub{font-size:14px;color:rgba(255,255,255,.65)}
.client-hero-logo{height:60px;width:auto;object-fit:contain;filter:brightness(0) invert(1);opacity:.9;flex-shrink:0}
.filter-bar{display:flex;gap:10px;margin-bottom:24px;flex-wrap:wrap;align-items:center}
.filter-label{font-family:'DM Mono',monospace;font-size:11px;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);white-space:nowrap}
.text-btn{background:none;border:none;color:var(--muted);font-size:13px;font-weight:700;font-family:'Barlow',sans-serif;cursor:pointer;text-decoration:underline;text-underline-offset:3px;padding:0}
.text-btn:hover{color:var(--text)}
.client-section-header{display:flex;align-items:center;gap:12px;margin:24px 0 12px}
.client-section-label{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:13px;letter-spacing:2px;text-transform:uppercase;white-space:nowrap}
.client-section-count{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted)}
.client-section-line{flex:1;height:2px;background:var(--border);border-radius:2px}
.client-delivery-card{background:var(--white);border:2px solid var(--border);border-radius:var(--radius-lg);padding:18px 20px;margin-bottom:10px;box-shadow:var(--shadow-sm)}
.client-delivery-card.status-delivered{border-left:5px solid var(--delivered)}.client-delivery-card.status-transit{border-left:5px solid var(--transit)}.client-delivery-card.status-pending{border-left:5px solid var(--pending-mid)}
.client-top{display:flex;justify-content:space-between;align-items:flex-start;gap:16px}
.client-name{font-weight:800;font-size:17px;color:var(--text)}
.client-address{color:var(--muted);font-size:14px;margin-top:3px}
.client-meta{font-family:'DM Mono',monospace;font-size:11px;color:var(--muted2);margin-top:6px}
.delivered-stamp{margin-top:10px;display:inline-flex;align-items:center;gap:6px;background:var(--delivered-light);border:1.5px solid var(--delivered-mid);border-radius:8px;padding:6px 12px;font-family:'DM Mono',monospace;font-size:12px;color:var(--delivered)}
.transit-stamp{margin-top:10px;display:inline-flex;align-items:center;gap:6px;background:var(--transit-light);border:1.5px solid var(--transit-mid);border-radius:8px;padding:6px 12px;font-family:'DM Mono',monospace;font-size:12px;color:var(--transit)}
.client-note{margin-top:10px;font-size:14px;color:var(--muted);font-style:italic;padding:10px 14px;background:var(--surface2);border-radius:8px;border-left:3px solid var(--border2)}
.empty-state{text-align:center;padding:72px 20px}
.empty-icon{font-size:40px;margin-bottom:14px}
.empty-title{font-family:'Barlow Condensed',sans-serif;font-size:24px;font-weight:800;text-transform:uppercase;margin-bottom:8px;color:var(--text)}
.empty-desc{font-size:14px;line-height:1.7;color:var(--muted)}
.loading-screen{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:300px;gap:16px}
.loading-spinner{width:36px;height:36px;border:3px solid var(--border);border-top-color:var(--bassett);border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-text{font-family:'DM Mono',monospace;font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--muted)}
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(4px)}
.modal-overlay.open{display:flex}
.modal-card{background:var(--white);border:2px solid var(--border);border-radius:var(--radius-lg);padding:36px;max-width:500px;width:100%;box-shadow:var(--shadow-lg);animation:fadeUp .25s ease both}
.modal-title{font-family:'Barlow Condensed',sans-serif;font-size:24px;font-weight:900;text-transform:uppercase;margin-bottom:6px;color:var(--text)}
.modal-desc{color:var(--muted);font-size:14px;margin-bottom:22px;line-height:1.7}
.modal-desc code{background:var(--surface2);border:1.5px solid var(--border);padding:2px 7px;border-radius:5px;font-family:'DM Mono',monospace;font-size:12px;color:var(--text)}
.drop-zone{border:2.5px dashed var(--border2);border-radius:var(--radius);padding:36px;text-align:center;cursor:pointer;transition:all .2s;color:var(--muted);margin-bottom:18px;background:var(--surface2)}
.drop-zone:hover,.drop-zone.drag-over{border-color:var(--muted);color:var(--text);background:var(--bg)}
.drop-icon{font-size:32px;margin-bottom:10px}
.modal-actions{display:flex;gap:10px;justify-content:flex-end}
.modal-cancel{background:none;border:2px solid var(--border);border-radius:10px;padding:11px 22px;color:var(--muted);font-family:'Barlow',sans-serif;font-weight:700;font-size:14px;cursor:pointer}
.modal-cancel:hover{color:var(--text);border-color:var(--border2)}
.toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(80px);background:#111;color:#fff;border-radius:12px;padding:14px 24px;font-size:14px;font-weight:700;font-family:'Barlow',sans-serif;z-index:999;transition:transform .35s cubic-bezier(.34,1.56,.64,1);white-space:nowrap;box-shadow:var(--shadow-lg)}
.toast.show{transform:translateX(-50%) translateY(0)}
.toast.success{background:var(--delivered)}.toast.info{background:var(--transit)}.toast.error{background:#dc2626}
@media(max-width:540px){.client-hero{flex-direction:column;align-items:flex-start}.client-hero-logo{height:44px}.app-main{padding:20px 14px}.stat-num{font-size:36px}}
</style>
</head>
<body>
<div id="login-screen">
  <div class="login-wrap">
    <div class="login-wordmark">
      <div class="login-wordmark-text">BFD</div>
      <div class="login-wordmark-sub">Delivery Tracking Page</div>
    </div>
    <div class="role-cards">
      <div class="role-card driver" id="role-driver" onclick="selectRole('driver')">
        <div class="role-driver-icon">🚐</div>
        <div class="role-label">Driver</div>
      </div>
      <div class="role-card bassett" id="role-bassett" onclick="selectRole(&apos;bassett&apos;)"><div class="role-logo-wrap"><img src="data:image/png;base64," alt="Bassett"></div><div class="role-label">Bassett</div></div>
      <div class="role-card enjoy" id="role-enjoy" onclick="selectRole(&apos;enjoy&apos;)"><div class="role-logo-wrap"><img src="data:image/png;base64," alt="Enjoy"></div><div class="role-label">Enjoy</div></div>
    </div>
    <div class="pin-card">
      <div class="pin-label">Enter PIN</div>
      <div class="pin-dots">
        <div class="pin-dot" id="dot0"></div>
        <div class="pin-dot" id="dot1"></div>
        <div class="pin-dot" id="dot2"></div>
        <div class="pin-dot" id="dot3"></div>
      </div>
      <div class="numpad">
        <button class="numpad-btn" onclick="numpadPress('1')">1</button>
        <button class="numpad-btn" onclick="numpadPress('2')">2</button>
        <button class="numpad-btn" onclick="numpadPress('3')">3</button>
        <button class="numpad-btn" onclick="numpadPress('4')">4</button>
        <button class="numpad-btn" onclick="numpadPress('5')">5</button>
        <button class="numpad-btn" onclick="numpadPress('6')">6</button>
        <button class="numpad-btn" onclick="numpadPress('7')">7</button>
        <button class="numpad-btn" onclick="numpadPress('8')">8</button>
        <button class="numpad-btn" onclick="numpadPress('9')">9</button>
        <button class="numpad-btn del" onclick="numpadPress('clear')">CLR</button>
        <button class="numpad-btn" onclick="numpadPress('0')">0</button>
        <button class="numpad-btn del" onclick="numpadPress('del')">⌫</button>
      </div>
    </div>
    <button class="sign-in-btn" onclick="doLogin()">Sign In →</button>
    <div class="login-error" id="login-error"></div>
    <div class="sync-status" id="sync-status">
      <div class="sync-dot pulse" id="sync-dot"></div>
      <span id="sync-text">Connecting...</span>
    </div>
  </div>
</div>
<div id="app" style="display:none;">
  <div class="app-header">
    <div class="header-left">
      <div>
        <div class="header-logo">BFD</div>
        <div class="header-role" id="header-role-label"></div>
      </div>
      <div class="header-divider"></div>
