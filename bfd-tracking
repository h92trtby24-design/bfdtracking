<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-app.js";
import { getFirestore, collection, doc, setDoc, deleteDoc, onSnapshot, writeBatch } from "https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore.js";

const firebaseConfig = {
  apiKey: "AIzaSyDf981Fu2L_Vh7IyZdHigsKpH8BXaWaWes",
  authDomain: "bfd-delivery.firebaseapp.com",
  projectId: "bfd-delivery",
  storageBucket: "bfd-delivery.firebasestorage.app",
  messagingSenderId: "696631074929",
  appId: "1:696631074929:web:a503b3b843fc631cfffbd0"
};

const fbApp = initializeApp(firebaseConfig);
const db = getFirestore(fbApp);

// expose firestore helpers globally so main.js can use them
window.db = db;
window.collection = collection;
window.doc = doc;
window.setDoc = setDoc;
window.deleteDoc = deleteDoc;
window.onSnapshot = onSnapshot;
window.writeBatch = writeBatch;
window.BASSETT_LOGO = 'data:image/png;base64,';
window.ENJOY_LOGO = 'data:image/png;base64,';

// wait for DOM then load main app
document.addEventListener('DOMContentLoaded', function() {
  // logos available after firebase init
  window.BASSETT_LOGO = window.BASSETT_LOGO;
  window.ENJOY_LOGO = window.ENJOY_LOGO;
});
</script>
<script>
const PINS = { driver: '1234', bassett: '2222', enjoy: '3333' };

var state = {
  role: null, account: 'bassett',
  selectedDate: todayStr(),
  deliveries: [],
  expandedId: null,
  driverSearch: '', clientSearch: '',
  clientDateFilter: todayStr(),
  pinBuffer: '',
  unsubscribe: null,
  connected: false
};

function todayStr() { return new Date().toISOString().slice(0,10); }
function esc(s) { return (s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

// ── SYNC STATUS ──
function setSyncStatus(status) {
  state.connected = status === 'live';
  var dot = document.getElementById('sync-dot');
  var text = document.getElementById('sync-text');
  var hdot = document.getElementById('header-sync-dot');
  var htext = document.getElementById('header-sync-text');
  if (status === 'live') {
    if (dot) { dot.className = 'sync-dot green'; }
    if (text) text.textContent = 'Live sync active';
    if (hdot) { hdot.className = 'header-sync-dot live'; }
    if (htext) htext.textContent = 'live';
  } else if (status === 'connecting') {
    if (dot) { dot.className = 'sync-dot pulse'; }
    if (text) text.textContent = 'Connecting...';
    if (hdot) { hdot.className = 'header-sync-dot pulse'; }
    if (htext) htext.textContent = 'connecting';
  } else {
    if (dot) { dot.className = 'sync-dot red'; }
    if (text) text.textContent = 'Offline';
    if (hdot) { hdot.className = 'header-sync-dot'; }
    if (htext) htext.textContent = 'offline';
  }
}

// ── FIRESTORE ──
function subscribeDeliveries() {
  if (state.unsubscribe) state.unsubscribe();
  setSyncStatus('connecting');
  var colRef = collection(db, 'deliveries');
  state.unsubscribe = onSnapshot(colRef,
    function(snapshot) {
      state.deliveries = [];
      snapshot.forEach(function(docSnap) {
        state.deliveries.push(docSnap.data());
      });
      setSyncStatus('live');
      renderApp();
    },
    function(err) {
      console.error('Firestore error:', err);
      setSyncStatus('offline');
      showToast('Sync error — check connection', 'error');
    }
  );
}

async function saveDeliveryToFirestore(d) {
  try {
    await setDoc(doc(db, 'deliveries', d.id), d);
  } catch(e) {
    console.error('Save error:', e);
    showToast('Save failed — check connection', 'error');
  }
}

async function saveBatchToFirestore(deliveries) {
  try {
    var batch = writeBatch(db);
    deliveries.forEach(function(d) {
      batch.set(doc(db, 'deliveries', d.id), d);
    });
    await batch.commit();
  } catch(e) {
    console.error('Batch save error:', e);
    showToast('Upload failed — check connection', 'error');
    throw e;
  }
}

// ── PIN / LOGIN ──
var selectedRole = null;

function selectRole(role) {
  selectedRole = role;
  ['driver','bassett','enjoy'].forEach(function(r) {
    document.getElementById('role-'+r).classList.remove('active');
  });
  document.getElementById('role-'+role).classList.add('active');
  state.pinBuffer = '';
  updateDots();
  document.getElementById('login-error').textContent = '';
}

function numpadPress(val) {
  if (!selectedRole) { document.getElementById('login-error').textContent = 'Select a role first'; return; }
  if (val === 'del') { state.pinBuffer = state.pinBuffer.slice(0,-1); }
  else if (val === 'clear') { state.pinBuffer = ''; }
  else if (state.pinBuffer.length < 4) { state.pinBuffer += val; }
  updateDots();
  document.getElementById('login-error').textContent = '';
  if (state.pinBuffer.length === 4) { setTimeout(doLogin, 140); }
}

function updateDots() {
  for (var i = 0; i < 4; i++) {
    var dot = document.getElementById('dot'+i);
    if (dot) dot.className = 'pin-dot' + (i < state.pinBuffer.length ? ' filled' : '');
  }
}

function doLogin() {
  if (!selectedRole) { document.getElementById('login-error').textContent = 'Select a role first'; return; }
  if (state.pinBuffer !== PINS[selectedRole]) {
    document.getElementById('login-error').textContent = 'Incorrect PIN — try again';
    state.pinBuffer = ''; updateDots(); return;
  }
  state.role = selectedRole;
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  subscribeDeliveries();
}

function doLogout() {
  if (state.unsubscribe) { state.unsubscribe(); state.unsubscribe = null; }
  state.role = null; selectedRole = null; state.pinBuffer = ''; updateDots();
  state.deliveries = [];
  document.getElementById('login-screen').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
  document.getElementById('login-error').textContent = '';
  ['driver','bassett','enjoy'].forEach(function(r) { document.getElementById('role-'+r).classList.remove('active'); });
  setSyncStatus('connecting');
}

// ── RENDER ──
function renderApp() {
  var labels = { driver: 'Driver View', bassett: 'Bassett Salon Solutions', enjoy: 'Enjoy Professional Hair Care' };
  document.getElementById('header-role-label').textContent = labels[state.role] || '';
  var logoEl = document.getElementById('header-brand-logo');
  if (state.role === 'bassett') { logoEl.src = BASSETT_LOGO; logoEl.style.display = 'block'; }
  else if (state.role === 'enjoy') { logoEl.src = ENJOY_LOGO; logoEl.style.display = 'block'; }
  else { logoEl.style.display = 'none'; }
  if (state.role === 'driver') renderDriverView();
  else renderClientView(state.role);
}

// ── DRIVER VIEW ──
function renderDriverView() {
  var list = getDriverDeliveries();
  var nd = list.filter(function(x){return x.status==='delivered';}).length;
  var nt = list.filter(function(x){return x.status==='transit';}).length;
  var np = list.filter(function(x){return x.status==='pending';}).length;
  var bImg = '<img src="'+BASSETT_LOGO+'" style="height:18px;border-radius:2px;" alt="B">';
  var eImg = '<img src="'+ENJOY_LOGO+'" style="height:16px;filter:brightness(0);" alt="E">';
  var html = '<div class="controls-bar">';
  html += '<div class="account-tabs">';
  html += '<button class="tab-btn '+(state.account==='bassett'?'active-bassett':'')+'" onclick="switchAccount(\'bassett\')">'+bImg+' Bassett</button>';
  html += '<button class="tab-btn '+(state.account==='enjoy'?'active-enjoy':'')+'" onclick="switchAccount(\'enjoy\')">'+eImg+' Enjoy</button>';
  html += '</div>';
  html += '<input type="date" class="date-picker" value="'+state.selectedDate+'" onchange="state.selectedDate=this.value;state.expandedId=null;renderApp()">';
  html += '<button class="icon-btn" onclick="openUploadModal()">📂 Upload CSV</button>';
  html += '<button class="icon-btn" onclick="clearRoute()" style="color:#f87171;">🗑️ Clear Route</button>';
  html += '<div class="search-wrap"><span class="search-icon">🔍</span>';
  html += '<input class="search-input" placeholder="Search stops, tracking..." value="'+esc(state.driverSearch)+'" oninput="state.driverSearch=this.value;renderApp()"></div>';
  html += '</div>';
  html += '<div class="stats-row">';
  html += '<div class="stat-card delivered"><div class="stat-num">'+nd+'</div><div class="stat-label">Delivered</div></div>';
  html += '<div class="stat-card transit"><div class="stat-num">'+nt+'</div><div class="stat-label">In-Transit</div></div>';
  html += '<div class="stat-card pending"><div class="stat-num">'+np+'</div><div class="stat-label">Pending</div></div>';
  html += '</div>';
  html += '<div class="section-label">'+formatDate(state.selectedDate)+' — '+state.account.toUpperCase()+' — '+list.length+' stop'+(list.length!==1?'s':'')+'</div>';
  html += '<div class="delivery-list">';
  html += list.length === 0 ? emptyState('No stops found','Upload a CSV or adjust your filters.') : list.map(driverCard).join('');
  html += '</div>';
  document.getElementById('app-main').innerHTML = html;
  if (state.expandedId) {
    var el = document.getElementById('expanded-'+state.expandedId);
    var ch = document.getElementById('chevron-'+state.expandedId);
    if (el) el.classList.add('open');
    if (ch) ch.classList.add('open');
  }
}

function driverCard(d) {
  var meta = [
    d.order_num ? 'Order #'+esc(d.order_num) : '',
    d.tracking  ? 'Track: '+esc(d.tracking) : '',
    d.packages > 1 ? d.packages+' pkgs' : ''
  ].filter(Boolean).join(' · ');
  var photo = d.photo ? '<img src="'+d.photo+'" class="photo-thumb" alt="proof">' : '';
  var ts = d.deliveredAt ? '<div class="timestamp-line">Updated: '+formatDateTime(d.deliveredAt)+'</div>' : '';
  var badge = d.status==='delivered' ? '✓ Delivered' : d.status==='transit' ? '⟳ In-Transit' : '· Pending';
  return '<div class="delivery-card status-'+d.status+'" id="card-'+d.id+'">'+
    '<div class="card-main" onclick="toggleCard(\''+d.id+'\')">'+
      '<div class="card-info">'+
        '<div class="card-name">'+esc(d.name)+'</div>'+
        '<div class="card-address">'+esc(d.address)+(d.city?', '+esc(d.city):'')+'</div>'+
        (meta ? '<div class="card-meta">'+meta+'</div>' : '')+
      '</div>'+
      '<div class="card-right">'+
        '<span class="card-badge badge-'+d.status+'">'+badge+'</span>'+
        '<span class="chevron" id="chevron-'+d.id+'">▾</span>'+
      '</div>'+
    '</div>'+
    '<div class="card-expanded" id="expanded-'+d.id+'">'+
      '<div class="action-row">'+
        '<button class="action-btn deliver '+(d.status==='delivered'?'active':'')+'" onclick="markStatus(\''+d.id+'\',\'delivered\')">✓ Mark Delivered</button>'+
        '<button class="action-btn transit '+(d.status==='transit'?'active':'')+'" onclick="markStatus(\''+d.id+'\',\'transit\')">⟳ In-Transit</button>'+
        '<button class="action-btn reset" onclick="markStatus(\''+d.id+'\',\'pending\')">↺ Reset</button>'+
      '</div>'+
      '<textarea class="note-input" placeholder="Add a note..." id="note-'+d.id+'" onblur="saveNote(\''+d.id+'\')">'+esc(d.note||'')+'</textarea>'+
      '<div class="photo-row">'+
        '<label class="photo-upload-label">📷 Add Photo<input type="file" accept="image/*" capture="environment" style="display:none" onchange="handlePhoto(\''+d.id+'\',this)"></label>'+
        photo+
      '</div>'+ts+
    '</div>'+
  '</div>';
}

function toggleCard(id) {
  var was = state.expandedId === id;
  if (state.expandedId) {
    var pe = document.getElementById('expanded-'+state.expandedId);
    var pc = document.getElementById('chevron-'+state.expandedId);
    if (pe) pe.classList.remove('open');
    if (pc) pc.classList.remove('open');
  }
  state.expandedId = was ? null : id;
  if (!was) {
    var el = document.getElementById('expanded-'+id);
    var ch = document.getElementById('chevron-'+id);
    if (el) el.classList.add('open');
    if (ch) ch.classList.add('open');
  }
}

function markStatus(id, status) {
  var d = state.deliveries.find(function(x){return x.id===id;});
  if (!d) return;
  d.status = status;
  d.deliveredAt = status !== 'pending' ? new Date().toISOString() : null;
  saveDeliveryToFirestore(d);
  showToast(status==='delivered'?'✓ Marked delivered':status==='transit'?'⟳ Marked in-transit':'↺ Reset to pending', status==='delivered'?'success':'info');
}

function saveNote(id) {
  var d = state.deliveries.find(function(x){return x.id===id;});
  var el = document.getElementById('note-'+id);
  if (d && el && el.value !== d.note) {
    d.note = el.value;
    saveDeliveryToFirestore(d);
  }
}

function handlePhoto(id, input) {
  var file = input.files[0]; if (!file) return;
  var r = new FileReader();
  r.onload = function(e) {
    var d = state.deliveries.find(function(x){return x.id===id;});
    if (d) { d.photo = e.target.result; saveDeliveryToFirestore(d); }
  };
  r.readAsDataURL(file);
}

function switchAccount(acc) { state.account = acc; state.expandedId = null; state.driverSearch = ''; renderApp(); }

function getDriverDeliveries() {
  var q = state.driverSearch.toLowerCase();
  return state.deliveries.filter(function(d) {
    if (d.account !== state.account || d.date !== state.selectedDate) return false;
    if (!q) return true;
    return [d.name,d.address,d.city||'',d.order_num||'',d.tracking||''].some(function(s){return s.toLowerCase().indexOf(q)>=0;});
  }).sort(function(a,b){ var o={pending:0,transit:1,delivered:2}; return o[a.status]-o[b.status]; });
}

// ── CLIENT VIEW ──
function renderClientView(account) {
  var q = state.clientSearch.toLowerCase();
  var all = state.deliveries.filter(function(d) {
    if (d.account !== account) return false;
    if (state.clientDateFilter && d.date !== state.clientDateFilter) return false;
    if (!q) return true;
    return [d.name,d.address,d.city||'',d.order_num||'',d.tracking||''].some(function(s){return s.toLowerCase().indexOf(q)>=0;});
  });
  var dList = all.filter(function(d){return d.status==='delivered';}).sort(function(a,b){return (b.deliveredAt||'').localeCompare(a.deliveredAt||'');});
  var tList = all.filter(function(d){return d.status==='transit';});
  var pList = all.filter(function(d){return d.status==='pending';});
  var logo = account==='bassett' ? BASSETT_LOGO : ENJOY_LOGO;
  var heroTitle = account==='bassett' ? 'Bassett Salon Solutions' : 'Enjoy Hair Care';
  var dateSub = state.clientDateFilter ? formatDate(state.clientDateFilter) : 'All Dates';

  var html = '<div class="client-hero '+account+'">';
  html += '<div class="client-hero-text">';
  html += '<div class="client-hero-eyebrow">Delivery Status Portal</div>';
  html += '<div class="client-hero-title">'+heroTitle+'</div>';
  html += '<div class="client-hero-sub">'+dateSub+' · '+all.length+' stop'+(all.length!==1?'s':'')+'</div>';
  html += '</div><img class="client-hero-logo" src="'+logo+'" alt="'+account+'"></div>';
  html += '<div class="filter-bar">';
  html += '<span class="filter-label">Date</span>';
  html += '<input type="date" class="date-picker" value="'+state.clientDateFilter+'" onchange="state.clientDateFilter=this.value;renderApp()">';
  html += '<button class="text-btn" onclick="state.clientDateFilter=\'\';renderApp()">View All</button>';
  html += '<div class="search-wrap" style="flex:1;min-width:180px;"><span class="search-icon">🔍</span>';
  html += '<input class="search-input" placeholder="Search name, salon, tracking #..." value="'+esc(state.clientSearch)+'" oninput="state.clientSearch=this.value;renderApp()"></div></div>';
  html += '<div class="stats-row">';
  html += '<div class="stat-card delivered"><div class="stat-num">'+dList.length+'</div><div class="stat-label">Delivered</div></div>';
  html += '<div class="stat-card transit"><div class="stat-num">'+tList.length+'</div><div class="stat-label">In-Transit</div></div>';
  html += '<div class="stat-card pending"><div class="stat-num">'+pList.length+'</div><div class="stat-label">Pending</div></div>';
  html += '</div>';
  if (all.length === 0) {
    html += emptyState('No deliveries found','Try a different date or clear your search.');
  } else {
    if (dList.length > 0) {
      html += '<div class="client-section-header"><span class="client-section-label" style="color:var(--delivered);">✓ Delivered</span><span class="client-section-count">'+dList.length+'</span><div class="client-section-line"></div></div>';
      html += dList.map(clientCard).join('');
    }
    if (tList.length > 0) {
      html += '<div class="client-section-header"><span class="client-section-label" style="color:var(--transit);">⟳ In-Transit</span><span class="client-section-count">'+tList.length+'</span><div class="client-section-line"></div></div>';
      html += tList.map(clientCard).join('');
    }
    if (pList.length > 0) {
      html += '<div class="client-section-header"><span class="client-section-label" style="color:#aaa;">· Pending</span><span class="client-section-count">'+pList.length+'</span><div class="client-section-line"></div></div>';
      html += pList.map(clientCard).join('');
    }
  }
  document.getElementById('app-main').innerHTML = html;
}

function clientCard(d) {
  var meta = [
    d.order_num ? 'Order #'+esc(d.order_num) : '',
    d.tracking  ? 'Tracking: '+esc(d.tracking) : '',
    d.packages > 1 ? d.packages+' packages' : ''
  ].filter(Boolean).join(' · ');
  var stamp = '';
  if (d.deliveredAt) {
    if (d.status==='delivered') stamp = '<div class="delivered-stamp">✓ Delivered '+formatDateTime(d.deliveredAt)+'</div>';
    else stamp = '<div class="transit-stamp">⟳ Updated '+formatDateTime(d.deliveredAt)+'</div>';
  }
  var note = d.note ? '<div class="client-note">📝 '+esc(d.note)+'</div>' : '';
  var badge = d.status==='delivered' ? '✓ Delivered' : d.status==='transit' ? '⟳ In-Transit' : '· Pending';
  return '<div class="client-delivery-card status-'+d.status+'">'+
    '<div class="client-top">'+
      '<div style="flex:1;min-width:0;">'+
        '<div class="client-name">'+esc(d.name)+'</div>'+
        '<div class="client-address">'+esc(d.address)+(d.city?', '+esc(d.city):'')+'</div>'+
        (meta ? '<div class="client-meta">'+meta+'</div>' : '')+
      '</div>'+
      '<span class="card-badge badge-'+d.status+'" style="flex-shrink:0;">'+badge+'</span>'+
    '</div>'+stamp+note+
    (d.photo ? '<div style="margin-top:12px;"><img src="'+d.photo+'" style="width:80px;height:80px;object-fit:cover;border-radius:10px;border:2px solid var(--border);" alt="proof"></div>' : '')+
  '</div>';
}

// ── CSV UPLOAD ──
function openUploadModal()  { document.getElementById('upload-modal').classList.add('open'); }
function closeUploadModal() { document.getElementById('upload-modal').classList.remove('open'); }

var dz = document.getElementById('drop-zone');
dz.addEventListener('dragover',  function(e){ e.preventDefault(); dz.classList.add('drag-over'); });
dz.addEventListener('dragleave', function()  { dz.classList.remove('drag-over'); });
dz.addEventListener('drop',      function(e){ e.preventDefault(); dz.classList.remove('drag-over'); handleCSVFile(e.dataTransfer.files[0]); });

async function clearRoute() {
  var acc = state.account;
  var dt = state.selectedDate;
  var toDelete = state.deliveries.filter(function(d) { return d.account === acc && d.date === dt; });
  if (toDelete.length === 0) { showToast('No stops to clear for this date', 'info'); return; }
  if (!confirm('Delete all ' + toDelete.length + ' stops for ' + acc.toUpperCase() + ' on ' + dt + '?\n\nThis cannot be undone.')) return;
  try {
    var batch = writeBatch(db);
    toDelete.forEach(function(d) { batch.delete(doc(db, 'deliveries', d.id)); });
    await batch.commit();
    showToast(toDelete.length + ' stops cleared ✓', 'success');
  } catch(e) {
    console.error('Clear error:', e);
    showToast('Clear failed — check connection', 'error');
  }
}

async function clearGhostData() {
  var ghosts = state.deliveries.filter(function(d) { return d.account !== 'bassett' && d.account !== 'enjoy'; });
  if (ghosts.length === 0) { showToast('No ghost data found', 'info'); return; }
  if (!confirm('Found ' + ghosts.length + ' orphaned records with invalid account values. Delete them all?')) return;
  try {
    var batch = writeBatch(db);
    ghosts.forEach(function(d) { batch.delete(doc(db, 'deliveries', d.id)); });
    await batch.commit();
    showToast(ghosts.length + ' ghost records cleared ✓', 'success');
  } catch(e) {
    console.error('Clear ghost error:', e);
    showToast('Clear failed — check connection', 'error');
  }
}

function handleCSVFile(file) {
  if (!file) return;
  var r = new FileReader();
  r.onload = function(e) {
    var rows = parseCSV(e.target.result);
    var newOnes = [];
    rows.forEach(function(row) {
      var name    = (row.name    || row.Name    || '').trim();
      var address = (row.address || row.Address || '').trim();
      var account = (row.account || row.Account || 'bassett').trim().toLowerCase();
      var date    = (row.date    || row.Date    || todayStr()).trim();
      var city    = (row.city    || row.City    || '').trim();
      var onum    = (row.order_num || row['Order #'] || '').trim();
      var track   = (row.tracking  || row.Tracking  || '').trim();
      var pkgs    = parseInt(row.packages || row.Packages || '1') || 1;
      if (!name || !address) return;
      var exists = state.deliveries.some(function(d){
        return d.account===account && d.date===date && d.name===name && d.address===address;
      });
      if (!exists) {
        var id = [account,date,name,address].join('_').replace(/\W+/g,'_').slice(0,64)+'_'+Math.random().toString(36).slice(2,6);
        newOnes.push({id:id,name:name,address:address,city:city,account:account,date:date,order_num:onum,tracking:track,packages:pkgs,status:'pending',note:'',deliveredAt:null,photo:null});
      }
    });
    if (newOnes.length === 0) {
      closeUploadModal();
      showToast('No new stops found', 'info');
      return;
    }
    closeUploadModal();
    showToast('Uploading '+newOnes.length+' stops...', 'info');
    saveBatchToFirestore(newOnes).then(function() {
      showToast(newOnes.length+' stop'+(newOnes.length!==1?'s':'')+' loaded ✓', 'success');
    });
  };
  r.readAsText(file);
}

function parseCSV(text) {
  var lines = text.trim().split('\n');
  if (lines.length < 2) return [];
  var headers = lines[0].split(',').map(function(h){ return h.trim().replace(/^"|"$/g,''); });
  return lines.slice(1).map(function(line) {
    var vals = line.split(',').map(function(v){ return v.trim().replace(/^"|"$/g,''); });
    var obj = {};
    headers.forEach(function(h,i){ obj[h] = vals[i] || ''; });
    return obj;
  });
}

// ── UTILS ──
function emptyState(t,d) {
  return '<div class="empty-state"><div class="empty-icon">📋</div><div class="empty-title">'+t+'</div><div class="empty-desc">'+d+'</div></div>';
}

function formatDate(s) {
  if (!s) return '';
  return new Date(s+'T12:00:00').toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'});
}

function formatDateTime(iso) {
  if (!iso) return '';
  var d = new Date(iso);
  return d.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric'})+' at '+d.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit'});
}

var toastTimer;
function showToast(msg, type) {
  type = type || 'info';
  var t = document.getElementById('toast');
  t.textContent = msg; t.className = 'toast '+type+' show';
  clearTimeout(toastTimer);
  toastTimer = setTimeout(function(){ t.classList.remove('show'); }, 3000);
}

</script>
